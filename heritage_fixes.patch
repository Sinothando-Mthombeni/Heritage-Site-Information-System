+BASE_DIR = Path(__file__).resolve().parent
+load_dotenv(BASE_DIR / ".env")
+
+
+def get_pg_connection():
+    return psycopg2.connect(
+        dbname=os.getenv("DB_NAME"),
+        user=os.getenv("DB_USER"),
+        password=os.getenv("DB_PASSWORD"),
+        host=os.getenv("DB_HOST"),
+        port=os.getenv("DB_PORT"),
+    )
+
+
+def get_mongo_db():
+    mongo_uri = os.getenv("MONGO_URI", "mongodb://localhost:27017/")
+    mongo_db_name = os.getenv("MONGO_DB_NAME", "heritage_phase3")
+    client = MongoClient(mongo_uri)
+    return client, client[mongo_db_name]
+
+
+def seed_heritage_sites(pg_cursor, mongo_db):
+    """
+    heritage_site stores province/category as foreign keys, so we join
+    against province/category to get human-readable names for the
+    denormalised Mongo documents that views_mongo.py and analytics.py
+    query by name (e.g. {"province": "Mpumalanga"}).
+
+    Field is named `entry_fee` to match heritage_backend.core.models
+    .HeritageSite.entry_fee and mongo/analytics.py's average_entry_fee()
+    pipeline, which both expect that exact name.
+    """
+    pg_cursor.execute("""
+        SELECT
+            hs.site_id,
+            hs.name,
+            p.name AS province,
+            c.name AS category,
+            hs.entry_fee,
+            hs.is_active
+        FROM heritage_site hs
+        JOIN province p ON p.province_id = hs.province_id
+        JOIN category c ON c.category_id = hs.category_id;
+    """)
+    sites = pg_cursor.fetchall()
+
+    mongo_db.heritage_sites.delete_many({})
+
+    if not sites:
+        return 0
+
+    mongo_db.heritage_sites.insert_many([
+        {
+            "site_id": s[0],
+            "name": s[1],
+            "province": s[2],
+            "category": s[3],
+            "entry_fee": float(s[4]) if s[4] is not None else None,
+            "is_active": s[5],
+            "reviews": [],
+        }
+        for s in sites
+    ])
+    return len(sites)
+
+
+def seed_bookings(pg_cursor, mongo_db):
+    """
+    booking has no site_name/province/visitors columns directly (those
+    were from an older flat schema) - join through heritage_site,
+    province, and visitor to rebuild the denormalised view Mongo needs.
+    """
+    pg_cursor.execute("""
+        SELECT
+            b.booking_id,
+            b.heritage_site_id AS site_id,
+            hs.name AS site_name,
+            p.name AS province,
+            b.number_of_people AS visitors,
+            b.booking_date,
+            b.visit_date,
+            v.full_name AS visitor_name,
+            v.email AS visitor_email
+        FROM booking b
+        JOIN heritage_site hs ON hs.site_id = b.heritage_site_id
+        JOIN province p ON p.province_id = hs.province_id
+        JOIN visitor v ON v.visitor_id = b.visitor_id;
+    """)
+    bookings = pg_cursor.fetchall()
+
+    mongo_db.bookings.delete_many({})
+
+    if not bookings:
+        return 0
+
+    mongo_db.bookings.insert_many([
+        {
+            "booking_id": b[0],
+            "site_id": b[1],
+            "site_name": b[2],
+            "province": b[3],
+            "visitors": b[4],
+            "booking_date": b[5].isoformat() if b[5] else None,
+            "visit_date": b[6].isoformat() if b[6] else None,
+            "visitor_name": b[7],
+            "visitor_email": b[8],
+        }
+        for b in bookings
+    ])
+    return len(bookings)
+
+
+def run():
+    pg_conn = get_pg_connection()
+    mongo_client, mongo_db = get_mongo_db()
+
+    try:
+        with pg_conn.cursor() as pg_cursor:
+            sites_count = seed_heritage_sites(pg_cursor, mongo_db)
+            bookings_count = seed_bookings(pg_cursor, mongo_db)
+    finally:
+        pg_conn.close()
+        mongo_client.close()
+
+    print(
+        f"MongoDB successfully seeded from PostgreSQL: "
+        f"{sites_count} heritage site(s), {bookings_count} booking(s)."
+    )
+
 
-print("MongoDB successfully seeded from PostgreSQL.")
